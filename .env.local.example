# このファイルをコピーして .env.local を作成し、実際の値を入力してください。
# .env.local はGitにコミットされません(.gitignoreで除外済み)。

# Supabaseダッシュボード > Project Settings > API から取得
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropicコンソール(console.anthropic.com) > API Keys から取得
ANTHROPIC_API_KEY=
